<Window xmlns="https://github.com/avaloniaui"
		xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
		xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
		xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
		xmlns:viewmodels="using:RA3_Nexus_Launcher.ViewModels"
		xmlns:enums="clr-namespace:RA3_Nexus_Launcher.Models.Enums"
		xmlns:converters="clr-namespace:RA3_Nexus_Launcher.Converters"
		mc:Ignorable="d"
		d:DesignWidth="720"
		d:DesignHeight="860"
		Width="720"
		Height="520"
		x:Class="RA3_Nexus_Launcher.Views.SettingsView"
		x:DataType="viewmodels:SettingsViewModel"
		FontFamily="avares://RA3_Nexus_Launcher/Assets/Fonts/#Hacen Tunisia"
		Title="Settings"
		Icon="/Assets/Launcher_Icon.ico"
		WindowStartupLocation="CenterOwner"
		Background="#FF2D2D2D">

	<Window.Resources>
		<converters:EnumToBoolConverter x:Key="EnumToBoolConverter" />
	</Window.Resources>

	<Window.Styles>
		<!-- Стили для кнопок -->
		<Style Selector="Button">
			<Setter Property="Background" Value="#FF404040"/>
			<Setter Property="Foreground" Value="White"/>
			<Setter Property="BorderBrush" Value="#FF555555"/>
			<Setter Property="BorderThickness" Value="1"/>
			<Setter Property="Padding" Value="10,5"/>
			<Setter Property="Margin" Value="2"/>
		</Style>

		<Style Selector="Button:pointerover">
			<Setter Property="Background" Value="#FF505050"/>
		</Style>

		<Style Selector="Button:pressed">
			<Setter Property="Background" Value="#FF303030"/>
		</Style>

		<!-- Стили для TextBox -->
		<Style Selector="TextBox">
			<Setter Property="Background" Value="#FF3A3A3A"/>
			<Setter Property="Foreground" Value="White"/>
			<Setter Property="BorderBrush" Value="#FF555555"/>
			<Setter Property="BorderThickness" Value="1"/>
			<Setter Property="Padding" Value="5"/>
		</Style>

		<!-- Стили для ComboBox -->
		<Style Selector="ComboBox">
			<Setter Property="Background" Value="#FF3A3A3A"/>
			<Setter Property="Foreground" Value="White"/>
			<Setter Property="BorderBrush" Value="#FF555555"/>
			<Setter Property="BorderThickness" Value="1"/>
		</Style>

		<!-- Стили для CheckBox -->
		<Style Selector="CheckBox">
			<Setter Property="Foreground" Value="White"/>
		</Style>

		<!-- Стили для TextBlock -->
		<Style Selector="TextBlock.HeaderText">
			<Setter Property="FontSize" Value="18"/>
			<Setter Property="Foreground" Value="#FFCCCCCC"/>
			<Setter Property="Margin" Value="0,0,0,10"/>
		</Style>
	</Window.Styles>

	<Grid ColumnDefinitions="Auto, *">
		<!-- Боковая панель навигации -->
		<StackPanel Grid.Column="0"
					Orientation="Vertical"
					HorizontalAlignment="Left"
					Background="#FF252525"
					MinWidth="200">
			<Border Background="#FF1E1E1E"
					CornerRadius="5"
					Padding="10"
					Margin="10,10,10,20">
				<TextBlock Text="SETTINGS"
						   TextAlignment="Center"
						   FontSize="22"
						   Foreground="White"/>
			</Border>

			<Button Classes="navButton"
					Tag="{x:Static enums:SettingsViewType.GlobalSettings}"
					MinWidth="160"
					MinHeight="40"
					Content="Global Settings"
					Margin="10,5"
					Background="#FF3A3A3A"
					Foreground="White"
					Command="{Binding ShowGlobalSettingsCommand}"/>

			<Button Classes="navButton"
					Tag="{x:Static enums:SettingsViewType.Patches}"
					MinWidth="160"
					MinHeight="40"
					Content="Patches"
					Margin="10,5"
					Background="#FF3A3A3A"
					Foreground="White"
					Command="{Binding ShowPatchesCommand}"/>
		</StackPanel>

		<!-- Основная область настроек -->
		<ScrollViewer Grid.Column="1"
					  Background="#FF363636">
			<Grid MaxWidth="800" Margin="20">
				<!-- Вкладка Global Settings -->
				<Grid Name="gridGlobalSettings"
					  RowDefinitions="Auto, Auto, Auto, Auto, Auto, Auto"
					  HorizontalAlignment="Left"
					  IsVisible="{Binding CurrentViewType, Converter={StaticResource EnumToBoolConverter}, ConverterParameter={x:Static enums:SettingsViewType.GlobalSettings}}">

					<TextBlock Grid.Row="0"
							   Margin="0,0,0,20"
							   FontSize="24"
							   Text="Game Settings"
							   Classes="HeaderText"/>

					<!-- Путь к игре -->
					<StackPanel Grid.Row="1"
								Orientation="Vertical"
								Margin="0,0,0,25">
						<TextBlock Text="Install Directory"
								   Classes="HeaderText"/>
						<Grid ColumnDefinitions="*, Auto, Auto"
							  Margin="0,10,0,0">
							<TextBox Grid.Column="0"
									 Name="txtGamePath"
									 Watermark="Select your RA3 installation directory..."
									 Text="{Binding SelectedGamePath}"
									 FontSize="12"/>
							<Button Grid.Column="1"
									Name="btReload"
									MinHeight="35"
									MinWidth="40"
									Margin="5,0,0,0"
									Command="{Binding ReloadGamePathCommand}"
									ToolTip.Tip="Auto-detect game path">
								<PathIcon Data="{Binding SyncArrowIconData}"/>
							</Button>
							<Button Grid.Column="2"
									Name="btSelect"
									MinHeight="35"
									MinWidth="40"
									Margin="5,0,0,0"
									Command="{Binding SelectGamePathCommand}"
									ToolTip.Tip="Browse for game directory">
								<PathIcon Data="{Binding OpenFolderIconData}"/>
							</Button>
						</Grid>
					</StackPanel>

					<!-- Настройки окна -->
					<StackPanel Grid.Row="2"
								Orientation="Vertical"
								Margin="0,0,0,25">
						<TextBlock Text="Windowing Settings"
								   Classes="HeaderText"/>
						<StackPanel Orientation="Vertical"
									Spacing="10"
									Margin="0,10,0,0">

							<StackPanel Orientation="Horizontal"
										Spacing="10"
										VerticalAlignment="Center">
								<TextBlock Text="Mode:"
										   VerticalAlignment="Center"
										   Foreground="White"
										   Width="80"/>
								<ComboBox ItemsSource="{Binding WindowParams}"
										  SelectedItem="{Binding SelectedWindowParam}"
										  IsEnabled="{Binding !IsCustomResoulution}"
										  MinWidth="150"/>
							</StackPanel>

							<StackPanel Orientation="Horizontal"
										Spacing="10"
										VerticalAlignment="Center">
								<CheckBox Name="chbUseCustomWindow"
										  IsChecked="{Binding IsCustomResoulution}"
										  VerticalAlignment="Center"/>
								<TextBlock Text="Custom Resolution"
										   VerticalAlignment="Center"
										   Foreground="White"/>
							</StackPanel>

							<StackPanel Orientation="Horizontal"
										Spacing="10"
										Margin="25,0,0,0"
										IsVisible="{Binding IsCustomResoulution}">
								<TextBox Watermark="Width"
										 Text="{Binding CustomResolutionWidth}"
										 MinWidth="80"/>
								<TextBlock Text="x"
										   VerticalAlignment="Center"
										   FontSize="16"
										   Foreground="White"/>
								<TextBox Watermark="Height"
										 Text="{Binding CustomResolutionHeight}"
										 MinWidth="80"/>
							</StackPanel>
						</StackPanel>
					</StackPanel>

					<!-- Параметры запуска -->
					<StackPanel Grid.Row="3"
								Orientation="Vertical"
								Margin="0,0,0,25">
						<TextBlock Text="Launch Parameters"
								   Classes="HeaderText"/>
						<Grid ColumnDefinitions="*, Auto"
							  RowDefinitions="Auto, Auto"
							  Margin="0,10,0,0">
							<TextBox Grid.Column="0" Grid.Row="0"
									 Name="txtLaunchParameters"
									 Watermark="Enter custom launch parameters separated by spaces..."
									 Text="{Binding LaunchParameters, Mode=TwoWay}"
									 AcceptsReturn="True"
									 FontSize="12"/>
							<Button Grid.Column="1" Grid.Row="0"
									Name="AllParameters"
									Margin="10,0,0,0"
									MinHeight="35"
									MinWidth="40"
									Command="{Binding OpenAllParametersCommand}"
									ToolTip.Tip="View available launch parameters">
								<PathIcon Data="{Binding ReadMoreIconData}"/>
							</Button>

							<StackPanel Grid.Column="0" Grid.Row="1"
										Orientation="Horizontal"
										Margin="0,15,0,0"
										Spacing="10">
								<TextBlock Text="Game Version:"
										   VerticalAlignment="Center"
										   Width="100"
										   Foreground="White"/>
								<ComboBox ItemsSource="{Binding AvailableVersions}"
										  SelectedItem="{Binding SelectedVersion}"
										  MinWidth="200"
										  HorizontalAlignment="Left">
								</ComboBox>
							</StackPanel>
						</Grid>
					</StackPanel>

					<!-- Параметры профилей -->
					<StackPanel Grid.Row="4"
								Orientation="Vertical"
								Margin="0,0,0,25">
						<TextBlock Text="Profile IP Settings"
								   Classes="HeaderText"/>

						<StackPanel Orientation="Vertical"
									Spacing="15"
									Margin="0,10,0,0">

							<StackPanel Orientation="Horizontal"
										Spacing="10">
								<TextBlock Text="Profile:"
										   VerticalAlignment="Center"
										   Width="100"
										   Foreground="White"/>
								<ComboBox ItemsSource="{Binding AvailableProfiles}"
										  SelectedItem="{Binding SelectedProfile}"
										  MinWidth="200"
										  HorizontalAlignment="Left">
									<ComboBox.ItemTemplate>
										<DataTemplate>
											<TextBlock Text="{Binding Name}"/>
										</DataTemplate>
									</ComboBox.ItemTemplate>
								</ComboBox>
							</StackPanel>

							<StackPanel Orientation="Horizontal"
										Spacing="10">
								<TextBlock Text="GameSpy IP:"
										   VerticalAlignment="Center"
										   Width="100"
										   Foreground="White"/>
								<ComboBox ItemsSource="{Binding AvailableIPs}"
										  SelectedItem="{Binding SelectedGameSpyId}"
										  MinWidth="200"
										  HorizontalAlignment="Left"/>
							</StackPanel>

							<StackPanel Orientation="Horizontal"
										Spacing="10">
								<TextBlock Text="IP Address:"
										   VerticalAlignment="Center"
										   Width="100"
										   Foreground="White"/>
								<ComboBox ItemsSource="{Binding AvailableIPs}"
										  SelectedItem="{Binding SelectedIp}"
										  MinWidth="200"
										  HorizontalAlignment="Left"/>
							</StackPanel>

							<StackPanel Orientation="Horizontal"
										Spacing="10"
										Margin="0,15,0,0">
								<Button Content="Apply IP Settings"
										Command="{Binding ApplyIpSettingsCommand}"
										MinWidth="120"/>

								<Button Content="Fix Skirmish Files"
										Command="{Binding FixSkirmishFileCommand}"
										MinWidth="120"
										ToolTip.Tip="Repairs all skirmish.ini files (does not delete them)"/>

								<Button Content="Enable Maps in Registry"
										Command="{Binding EnableMapsInRegistryCommand}"
										MinWidth="150"
										ToolTip.Tip="Enable Maps in Registry (Requires admin privileges)"/>
							</StackPanel>

							<StackPanel Orientation="Vertical"
										Spacing="10"
										Margin="0,15,0,0">

								<TextBlock Text="Language Settings"
										   Classes="HeaderText"/>

								<StackPanel Orientation="Horizontal" Spacing="10">
									<TextBlock Text="Language:"
											   VerticalAlignment="Center"
											   Width="100"
											   Foreground="White"/>

									<ComboBox ItemsSource="{Binding AvailableLanguages}"
											  SelectedItem="{Binding SelectedLanguage}"
											  MinWidth="200"
											  VerticalAlignment="Center"/>

									<Button Content="Apply Language"
											Command="{Binding ApplyLanguageCommand}"
											MinWidth="150"
											VerticalAlignment="Center"
											ToolTip.Tip='Changes the selected language in the game (may help with the error "Could not find game version? Please make sure you have the latest patch installed")'/>
								</StackPanel>
							</StackPanel>
						</StackPanel>
					</StackPanel>
				</Grid>

				<!-- Вкладка Patches -->
				<StackPanel Name="panelPatches"
							Margin="0,0,0,20"
							IsVisible="{Binding CurrentViewType, Converter={StaticResource EnumToBoolConverter}, ConverterParameter={x:Static enums:SettingsViewType.Patches}}">
					<TextBlock Text="Patches Settings" FontSize="24" Classes="HeaderText"/>

					<StackPanel Spacing="5">
						<Button Content="Install 4GB Patch"
								Command="{Binding InstallFourGBPatchCommand}"
								Margin="0,5,0,0"
								ToolTip.Tip="Increases the amount of RAM available to the game (requires administrator privileges)" />

						<Button Content="Fix Registry"
								Command="{Binding FixRegistryCommand}"
								Margin="0,5,0,0"
								ToolTip.Tip="Fixes common registry errors that may cause the game to crash or fail to launch" />

						<Button Content="Generate New CD Key"
								Command="{Binding GenerateCDKeyCommand}"
								Margin="0,5,0,0"
								ToolTip.Tip="Generates a new unique CD key to prevent conflicts with other installations" />

						<Button Content="Download RA3 BattleNet"
								Command="{Binding OpenRA3BattleNetUrlCommand}"
								Margin="0,5,0,0"
								ToolTip.Tip="Downloads the RA3 BattleNet client for online multiplayer matches" />

						<Button Content="Download Tacitus (CnC Online)"
								Command="{Binding OpenTacitusUrlCommand}"
								Margin="0,5,0,0"
								ToolTip.Tip="Downloads Tacitus, a community-driven platform for CnC games online play" />

						<Button Content="Download Radmin VPN"
								Command="{Binding OpenRadminVPNUrlCommand}"
								Margin="0,5,0,0"
								ToolTip.Tip="Downloads Radmin VPN for creating local network rooms and playing with friends" />
					</StackPanel>
				</StackPanel>
			</Grid>
		</ScrollViewer>
	</Grid>
</Window>