<Window xmlns="https://github.com/avaloniaui"
		xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
		xmlns:vm="using:RA3_Nexus_Launcher.ViewModels"
		xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
		xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
		xmlns:views="clr-namespace:RA3_Nexus_Launcher.Views"
		mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="675"
		Width="1200"
		Height="675"
		x:Class="RA3_Nexus_Launcher.Views.MainWindow"
		Icon="/Assets/avalonia-logo.ico"
		Title="RA3_Nexus_Launcher">
	<views:MainView />
</Window>
