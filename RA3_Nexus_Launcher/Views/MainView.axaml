<UserControl xmlns="https://github.com/avaloniaui"
			 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
			 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
			 xmlns:vm="clr-namespace:RA3_Nexus_Launcher.ViewModels"
			 mc:Ignorable="d" d:DesignWidth="1280" d:DesignHeight="720"
			 x:Class="RA3_Nexus_Launcher.Views.MainView"
			 x:DataType="vm:MainViewModel"
			 Padding="0">

	<UserControl.Background>
		<ImageBrush Source="avares://RA3_Nexus_Launcher/Assets/Background.png"
					Stretch="Fill"
					AlignmentX="Center"
					AlignmentY="Center" />
	</UserControl.Background>

	<Grid RowDefinitions="Auto, *, Auto">
		<StackPanel Grid.Row="0"
					Orientation="Horizontal"
					HorizontalAlignment="Right"
					VerticalAlignment="Top"
					FlowDirection="RightToLeft"
					Spacing="4">

			<Button	Foreground="Black"
					Classes="window"
					Name="CloseButton"
					Width="32"
					Height="32"
					CornerRadius="0"
					Command="{Binding CloseWindowCommand}"
					HorizontalAlignment="Right"
					VerticalAlignment="Top"
					Content="✕"/>

			<Button Margin="0.75,0,0,0"
					Foreground="Black"
					Classes="window"
					Name="MinimizeButton"
					Width="32"
					Height="32"
					CornerRadius="0"
					Command="{Binding MinimizeWindowCommand}"
					HorizontalAlignment="Right"
					VerticalAlignment="Top"
					Content="—"/>
		</StackPanel>

		<Grid Grid.Row="2"
			  ColumnDefinitions="Auto,250,Auto"
			  RowDefinitions="Auto, Auto"
			  HorizontalAlignment="Center"
			  Margin="0,0,0,40">

			<Button Grid.Column="0" Grid.Row="0"
					Name="btnBattleNet"
					Classes="menu"
					Width="50"
					Height="50"
					BorderThickness="1"
					BorderBrush="#ecc084">
				<Canvas Width="35" Height="35">
					<Canvas.RenderTransform>
						<ScaleTransform ScaleX="1" ScaleY="-1" />
					</Canvas.RenderTransform>
					<PathIcon Width="35"
							  Height="35"
							  VerticalAlignment="Center"
							  HorizontalAlignment="Center"
							  Data="M496 919 c-2 -8 -18 -55 -35 -106 -17 -51 -31 -94 -31 -98 0 -3 36 -5 79 -5 l80 0 -36 103 c-36 106 -49 130 -57 106z
							  M436 668 c-56 -15 -128 -90 -145 -150 -50 -179 142 -344 304 -260 188 96 157 364 -47 412 -51 11 -61 11 -112 -2z m71 -175 c47 -53 61 -63 80 -58 25 6 30 -4 11 -23 -9 -9 -6 -18 15 -40 32 -34 34 -42 7 -42 -11 0 -20 4 -20 10 0 17 -40 33 -54 21 -18 -15 -29 -1 -14 17 10 11 9 17 -5 27 -35 25 -117 106 -127 124 -40 75 30 52 107 -36z m94 39 c-7 -15 -22 -35 -35 -44 -23 -16 -25 -16 -41 2 -17 19 -17 21 1 41 24 27 78 51 83 38 1 -6 -2 -22 -8 -37z m-112 -109 c3 -2 -4 -9 -14 -17 -15 -11 -17 -17 -7 -28 15 -18 4 -32 -14 -17 -14 12 -54 -4 -54 -21 0 -6 -9 -10 -20 -10 -27 0 -25 8 7 42 21 22 24 31 15 40 -19 19 -14 29 12 22 13 -3 27 -1 31 6 5 8 11 8 23 -2 10 -7 19 -14 21 -15z
							  M36 601 c22 -21 198 -150 201 -147 2 2 10 27 18 57 8 30 17 64 21 77 6 22 6 22 -122 22 -77 0 -124 -4 -118 -9z
							  M 828 602 C 774 601 730 596 730 592 C 730 588 739 557 749 523 C 759 490 766 449 764 433 C 762 418 819 464 876 506 C 934 548 979 587 977 594 C 973 606 969 606 828 602 Z
							  M 732 294 C 735 312 708 284 633 234 C 604 216 563 186 573 188 C 582 190 635 157 691 115 C 747 73 794 41 797 43 C 799 45 796 60 789 76 C 765 140 729 275 732 294 Z
							  M 251 182 C 233 123 215 69 213 63 C 202 34 249 54 339 118 C 392 156 458 199 443 199 C 420 200 343 248 320 275 C 313 283 302 290 296 290 C 290 290 270 241 251 182 Z"
							  Foreground="#ecc084"/>
				</Canvas>
			</Button>

			<Button Grid.Column="1" Grid.Row="0"
					Name="btnLaunch"
					Margin="5,0,5,0"
					Width="250"
					Height="50"
					Content="Launch"
					Classes="launch"
					FontFamily="avares://RA3_Nexus_Launcher/Assets/Fonts/#Hacen Tunisia"
					FontSize="28"
					VerticalContentAlignment="Center"
					HorizontalContentAlignment="Center"
					BorderThickness="1"
					Foreground="#edd0a6"
					BorderBrush="#ecc084"/>

			<ComboBox Grid.Column="1" Grid.Row="1"
					  Name="cmbModList"
					  Margin="5,5,5,0"
					  MinWidth="250"
					  Height="40"
					  BorderBrush="#ecc084"
					  Background="#33FFFFFF"
					  FontFamily="avares://RA3_Nexus_Launcher/Assets/Fonts/#Hacen Tunisia"
					  FontSize="16"
					  IsVisible="True">
				<ComboBoxItem Content="Текст для первого элемента"
							  FontFamily="avares://RA3_Nexus_Launcher/Assets/Fonts/#Hacen Tunisia"
							  FontSize="16"/>
			</ComboBox>

			<Button Grid.Column="2" Grid.Row="0"
					Name="btnSettings"
					Classes="menu"
					MinWidth="50"
					MinHeight="50"
					BorderThickness="1"
					BorderBrush="#ecc084">
				<PathIcon Width="30"
						  Height="30"
						  VerticalAlignment="Center"
						  HorizontalAlignment="Center"
						  Data="M12.012 2.25c.734.008 1.465.093 2.182.253a.75.75 0 0 1 .582.649l.17 1.527a1.384 1.384 0 0 0 1.927 1.116l1.401-.615a.75.75 0 0 1 .85.174 9.792 9.792 0 0 1 2.204 3.792.75.75 0 0 1-.271.825l-1.242.916a1.381 1.381 0 0 0 0 2.226l1.243.915a.75.75 0 0 1 .272.826 9.797 9.797 0 0 1-2.204 3.792.75.75 0 0 1-.848.175l-1.407-.617a1.38 1.38 0 0 0-1.926 1.114l-.169 1.526a.75.75 0 0 1-.572.647 9.518 9.518 0 0 1-4.406 0 .75.75 0 0 1-.572-.647l-.168-1.524a1.382 1.382 0 0 0-1.926-1.11l-1.406.616a.75.75 0 0 1-.849-.175 9.798 9.798 0 0 1-2.204-3.796.75.75 0 0 1 .272-.826l1.243-.916a1.38 1.38 0 0 0 0-2.226l-1.243-.914a.75.75 0 0 1-.271-.826 9.793 9.793 0 0 1 2.204-3.792.75.75 0 0 1 .85-.174l1.4.615a1.387 1.387 0 0 0 1.93-1.118l.17-1.526a.75.75 0 0 1 .583-.65c.717-.159 1.45-.243 2.201-.252Zm0 1.5a9.135 9.135 0 0 0-1.354.117l-.109.977A2.886 2.886 0 0 1 6.525 7.17l-.898-.394a8.293 8.293 0 0 0-1.348 2.317l.798.587a2.881 2.881 0 0 1 0 4.643l-.799.588c.32.842.776 1.626 1.348 2.322l.905-.397a2.882 2.882 0 0 1 4.017 2.318l.11.984c.889.15 1.798.15 2.687 0l.11-.984a2.881 2.881 0 0 1 4.018-2.322l.905.396a8.296 8.296 0 0 0 1.347-2.318l-.798-.588a2.881 2.881 0 0 1 0-4.643l.796-.587a8.293 8.293 0 0 0-1.348-2.317l-.896.393a2.884 2.884 0 0 1-4.023-2.324l-.11-.976a8.988 8.988 0 0 0-1.333-.117ZM12 8.25a3.75 3.75 0 1 1 0 7.5 3.75 3.75 0 0 1 0-7.5Zm0 1.5a2.25 2.25 0 1 0 0 4.5 2.25 2.25 0 0 0 0-4.5Z"
						  Foreground="#ecc084"/>
			</Button>
		</Grid>

		<TextBlock Grid.Column="2" Grid.Row="2"
				   Name="txtVersion"
				   Text="v1.0"
				   FontSize="20"
				   FontWeight="Bold"
				   Foreground="#ecc084"
				   Margin="0,0,96,25"
				   HorizontalAlignment="Right"
				   VerticalAlignment="Bottom"/>

		<StackPanel Grid.Column="0" Grid.Row="2"
					Orientation="Horizontal"
					FlowDirection="LeftToRight"
					Margin="140,0,0,-85"
					Spacing="5">

			<Button Name="btnDiscord"
					Width="40"
					Height="40"
					Classes="window"
					Command="{Binding OpenDiscordChannelCommand}"
					ToolTip.Tip="Discord Server">
				<Button.Content>
					<PathIcon Width="25"
							  Height="25"
							  VerticalAlignment="Center"
							  HorizontalAlignment="Center"
							  Data="M13.545 2.907a13.2 13.2 0 0 0-3.257-1.011.05.05 0 0 0-.052.025c-.141.25-.297.577-.406.833a12.2 12.2 0 0 0-3.658 0 8 8 0 0 0-.412-.833.05.05 0 0 0-.052-.025c-1.125.194-2.22.534-3.257 1.011a.04.04 0 0 0-.021.018C.356 6.024-.213 9.047.066 12.032q.003.022.021.037a13.3 13.3 0 0 0 3.995 2.02.05.05 0 0 0 .056-.019q.463-.63.818-1.329a.05.05 0 0 0-.01-.059l-.018-.011a9 9 0 0 1-1.248-.595.05.05 0 0 1-.02-.066l.015-.019q.127-.095.248-.195a.05.05 0 0 1 .051-.007c2.619 1.196 5.454 1.196 8.041 0a.05.05 0 0 1 .053.007q.121.1.248.195a.05.05 0 0 1-.004.085 8 8 0 0 1-1.249.594.05.05 0 0 0-.03.03.05.05 0 0 0 .003.041c.24.465.515.909.817 1.329a.05.05 0 0 0 .056.019 13.2 13.2 0 0 0 4.001-2.02.05.05 0 0 0 .021-.037c.334-3.451-.559-6.449-2.366-9.106a.03.03 0 0 0-.02-.019m-8.198 7.307c-.789 0-1.438-.724-1.438-1.612s.637-1.613 1.438-1.613c.807 0 1.45.73 1.438 1.613 0 .888-.637 1.612-1.438 1.612m5.316 0c-.788 0-1.438-.724-1.438-1.612s.637-1.613 1.438-1.613c.807 0 1.451.73 1.438 1.613 0 .888-.631 1.612-1.438 1.612"
							  Foreground="#ecc084"/>
				</Button.Content>
			</Button>

			<Button Name="btnGithub"
					Width="40"
					Height="40"
					Classes="window"
					Command="{Binding OpenGithubCommand}"
					ToolTip.Tip="Github Page">
				<Button.Content>
					<PathIcon Width="25"
							  Height="25"
							  VerticalAlignment="Center"
							  HorizontalAlignment="Center"
							  Data="M41.4395 69.3848C28.8066 67.8535 19.9062 58.7617 19.9062 46.9902C19.9062 42.2051 21.6289 37.0371 24.5 33.5918C23.2559 30.4336 23.4473 23.7344 24.8828 20.959C28.7109 20.4805 33.8789 22.4902 36.9414 25.2656C40.5781 24.1172 44.4062 23.543 49.0957 23.543C53.7852 23.543 57.6133 24.1172 61.0586 25.1699C64.0254 22.4902 69.2891 20.4805 73.1172 20.959C74.457 23.543 74.6484 30.2422 73.4043 33.4961C76.4668 37.1328 78.0937 42.0137 78.0937 46.9902C78.0937 58.7617 69.1934 67.6621 56.3691 69.2891C59.623 71.3945 61.8242 75.9883 61.8242 81.252L61.8242 91.2051C61.8242 94.0762 64.2168 95.7031 67.0879 94.5547C84.4102 87.9512 98 70.6289 98 49.1914C98 22.1074 75.9883 6.69539e-07 48.9043 4.309e-07C21.8203 1.92261e-07 -1.9479e-07 22.1074 -4.3343e-07 49.1914C-6.20631e-07 70.4375 13.4941 88.0469 31.6777 94.6504C34.2617 95.6074 36.75 93.8848 36.75 91.3008L36.75 83.6445C35.4102 84.2188 33.6875 84.6016 32.1562 84.6016C25.8398 84.6016 22.1074 81.1563 19.4277 74.7441C18.375 72.1602 17.2266 70.6289 15.0254 70.3418C13.877 70.2461 13.4941 69.7676 13.4941 69.1934C13.4941 68.0449 15.4082 67.1836 17.3223 67.1836C20.0977 67.1836 22.4902 68.9063 24.9785 72.4473C26.8926 75.2227 28.9023 76.4668 31.2949 76.4668C33.6875 76.4668 35.2187 75.6055 37.4199 73.4043C39.0469 71.7773 40.291 70.3418 41.4395 69.3848Z"
							  Foreground="#ecc084"/>
				</Button.Content>
			</Button>

			<Button Name="btnModDB"
					Width="40"
					Height="40"
					Classes="window"
					Command="{Binding OpenModDbCommand}"
					ToolTip.Tip="ModDB">
				<Button.Content>
					<Canvas Width="25" Height="25">
						<Canvas.RenderTransform>
							<ScaleTransform ScaleX="1" ScaleY="-1" />
						</Canvas.RenderTransform>
						<PathIcon Width="25"
								  Height="25"
								  VerticalAlignment="Center"
								  HorizontalAlignment="Center"
